#!/usr/bin/env python3
"""
AgentMux Development Wrapper

This wrapper script allows developers to use the installed version of agentmux
while working on the agentmux source code itself. It removes the current directory
from Python's import path to prevent the local source from being imported.

Usage:
    ./agentmux-dev "Your feature description"
    ./agentmux-dev init
    ./agentmux-dev resume

Installation:
    # Make executable and symlink to PATH
    chmod +x agentmux-dev
    ln -s $(pwd)/agentmux-dev ~/.local/bin/agentmux-dev

    # Or use directly from repo
    ./agentmux-dev "Add new feature"

Why this is needed:
    When running `agentmux` from within the agentmux repository, Python's import
    system finds the local `agentmux/` package before the installed version.
    This wrapper removes the current directory from sys.path, ensuring the
    installed version is used instead.
"""

import sys

# Remove current directory and empty strings from sys.path
# This prevents Python from finding the local agentmux package
sys.path = [p for p in sys.path if p not in ("", ".")]

from agentmux.pipeline import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
