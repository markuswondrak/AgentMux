#!/usr/bin/env python3
"""
AgentMux Development Wrapper

Thin launcher for running the installed agentmux CLI from within the
repository. With the src/ layout the package lives under src/agentmux/,
so the repository root is no longer on the import path and shadowing
cannot occur. This wrapper simply delegates to the installed entry point.

Usage:
    ./agentmux-dev "Your feature description"
    ./agentmux-dev init
    ./agentmux-dev resume

Installation:
    # Make executable and symlink to PATH
    chmod +x agentmux-dev
    ln -s $(pwd)/agentmux-dev ~/.local/bin/agentmux-dev

    # Or use directly from repo
    ./agentmux-dev "Add new feature"
"""

import sys

from agentmux.pipeline import main

if __name__ == "__main__":
    sys.exit(main())
